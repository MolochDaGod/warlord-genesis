{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm config set minimumReleaseAge 0 && pnpm install --frozen-lockfile",
  "buildCommand": "BASE_PATH=/ PORT=5173 pnpm --filter @workspace/grudge-warlords run build",
  "outputDirectory": "artifacts/grudge-warlords/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "https://assets.grudge-studio.com/assets/$1" },
    { "source": "/anims/(.*)", "destination": "https://assets.grudge-studio.com/anims/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}