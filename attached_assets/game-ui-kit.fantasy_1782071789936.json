    "--gk-fr-slot-shadow": "inset 0 2px 6px rgba(0,0,0,0.4)"
  },
  "overrides": {
    "--gk-surface": "#241412",
    "--gk-accent": "#c0392b",
    "--gk-xp": "#000000",
    "--gk-ink": "#f3dcc4",
    "--gk-surface-2": "#33201c",
    "--gk-ink-dim": "#000000",
    "--gk-accent-2": "#e0b252",
    "--gk-bg": "#160d0b"
