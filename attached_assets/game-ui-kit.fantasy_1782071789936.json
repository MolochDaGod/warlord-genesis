{
  "theme": "fantasy",
  "baseVars": {
    "--gk-font": "\"Cinzel Decorative\", \"Cinzel\", Georgia, serif",
    "--gk-font-body": "\"EB Garamond\", Georgia, serif",
    "--gk-font-scale": "1",
    "--gk-radius": "10px",
    "--gk-bg": "#241a12",
    "--gk-surface": "#efe2c4",
    "--gk-surface-2": "#e3d2ab",
    "--gk-ink": "#3a2a17",
    "--gk-ink-dim": "#7c6646",
    "--gk-accent": "#b8860b",
    "--gk-accent-2": "#8a3324",
    "--gk-good": "#5a8f3c",
