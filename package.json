{
  "name": "warlord-genesis",
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "license": "MIT",
  "private": true,
  "description": "Grudge Warlords warcamp client — https://warlord-genesis.vercel.app",
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.includes('pnpm')){console.error('Use pnpm instead');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:ci": "node scripts/ci-build.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "verify": "node scripts/verify-deploy.mjs",
    "verify:live": "node scripts/verify-deploy.mjs --live",
    "deploy": "node scripts/deploy.mjs",
    "deploy:vercel": "node scripts/vercel-deploy.mjs",
    "patch": "node scripts/patch-bundle.mjs",
    "syntax": "node scripts/check-esbuild.mjs",
    "textures:ground": "node scripts/generate-ground-textures.mjs",
    "textures:battle": "node scripts/generate-battle-textures.mjs",
    "textures:race": "node scripts/stage-textures.mjs",
    "assets:stage": "node scripts/stage-assets.mjs",
    "assets:heroes": "node scripts/stage-heroes.mjs",
    "assets:heroes:upload": "node scripts/upload-heroes-r2.mjs",
    "assets:icons": "node scripts/stage-icons.mjs",
    "import:baseline": "node scripts/import-source-baseline.mjs",
    "vercel:config": "node scripts/generate-vercel-config.mjs",
    "api:dev": "cd api && npm run dev",
    "api:migrate": "cd api && npm run db:migrate",
    "assets:fix-glb": "node scripts/fix-glb-header.mjs models/towers",
    "assets:strip": "node scripts/fix-glb-header.mjs models/towers && node scripts/strip-glb-external-textures.mjs models/towers",
    "assets:download": "node scripts/download-towers.mjs",
    "assets:upload-r2": "node scripts/upload-r2.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
