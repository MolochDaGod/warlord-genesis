# ── Vercel (warlord-genesis frontend) ─────────────────────────────
# Set in Vercel Project → Settings → Environment Variables (Production)

# Canonical GrudgeBuilder Railway API (characters, wallet, islands)
GRUDGE_API_URL=https://grudge-api-production-0d46.up.railway.app

# Warlord Genesis game API on Railway (auth adapter, player saves)
WARLORD_GENESIS_API_URL=https://warlord-genesis-api-production.up.railway.app

# ── Railway (warlord-genesis-api service) ─────────────────────────
# Link Postgres from grudge-studio-api / grudge-warlords-db project

DATABASE_URL=postgresql://user:pass@host:5432/neondb?sslmode=require
GRUDGE_API_URL=https://grudge-api-production-0d46.up.railway.app
PORT=8787

# Optional: run migrations locally
# cd api && npm install && npm run db:migrate